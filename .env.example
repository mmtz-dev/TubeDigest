# Gemini API key (required for Gemini summarization provider)
GEMINI_API_KEY=your_gemini_api_key_here

# Port to run the app on (default: 5555)
PORT=5555

# Claude proxy URL (for Docker → host Claude Code access)
# CLAUDE_PROXY_URL=http://host.docker.internal:9100

# Custom output directories (optional, defaults to ./Transcriptions and ./Summaries)
# TRANSCRIPTIONS_DIR=/path/to/transcriptions
# SUMMARIES_DIR=/path/to/summaries
